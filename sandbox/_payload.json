[{"data":1,"prerenderedAt":211},["ShallowReactive",2],{"/sandbox":3,"sidebar-top-/sandbox":108,"sidebar-bottom-undefined":209,"sidebar-bottom-title-undefined":210,"sidebar-top-title-/sandbox":5},{"id":4,"title":5,"body":6,"description":97,"extension":100,"hideBreadcrumb":101,"hideToc":101,"meta":102,"navigation":103,"path":105,"seo":106,"stem":107},"content_en/sandbox/0.index.md","Karagäz Sandbox",{"type":7,"value":8,"toc":96},"minimal",[9,13,21,24,39,48,56,59,62,72,78,81],[10,11,5],"h1",{"id":12},"karagäz-sandbox",[14,15,17],"hint",{"variant":16},"destructive",[18,19,20],"p",{},"Keep in mind that Karagöz is still in active development and things might change in the near future.\nUse in production at your own risk.",[22,23],"br",{},[14,25,26,36],{"variant":16},[18,27,28,29,35],{},"Feedback and improvement ideas are welcome by opening issues and discussions in the ",[30,31,34],"a",{"href":32,"target":33},"https://github.\ncom/frontendat/karagoz","_blank","GitHub repo",".",[18,37,38],{},"Contributions to the code will be accepted and appreciated as well, once a proper process has been defined.",[18,40,41,42,35],{},"The idea behind Karagöz Sandbox is to provide a simple UI to work with\n",[30,43,47],{"className":44,"href":46,"target":33},[45],"external","https://webcontainers.io/","WebContainers",[18,49,50,51,35],{},"If you're not familiar with WebContainers, please check out\n",[30,52,55],{"className":53,"href":54,"target":33},[45],"https://webcontainer-tutorial.pages.dev/","this tutorial",[18,57,58],{},"In short, it is a browser-based runtime developed by StackBlitz. Once you boot a WebContainer in the browser, you\ncan mount a collection of files within it and spawn processes such as installing dependencies and starting a\ndevelopment server using shell or your favorite package manager(NPM, PNPM and Yarn come preinstalled).",[18,60,61],{},"With Karagöz Sandbox on top of that, you will get something like the following:",[14,63,64],{},[18,65,66,67,71],{},"Due to limitations set in the design of the WebContainer API, ",[68,69,70],"strong",{},"only one"," WebContainer instance can be running at a\ntime.\nBecause of that, starting one of the demos on one of the documentation pages will terminate any previously running demos.",[73,74,75],"demo-runner",{},[76,77],"sandbox-demo-full",{},[18,79,80],{},"Karagöz Sandbox stands on the shoulders of giants to provide as simple, intuitive UI.",[18,82,83,84,89,90,95],{},"Aside from WebContainers, it uses\n",[30,85,88],{"className":86,"href":87,"target":33},[45],"https://codemirror.net/","CodeMirror"," for code editing and\n",[30,91,94],{"className":92,"href":93,"target":33},[45],"https://xtermjs.org/","Xterm.js"," to interact with the terminal and display the output of running processes.",{"title":97,"searchDepth":98,"depth":98,"links":99},"",2,[],"md",true,{},{"sidebarTitle":5,"title":104},"Introduction","/sandbox",{"title":5,"description":97},"sandbox/0.index",[109],{"title":104,"path":105,"stem":107,"children":110,"sidebarTitle":5},[111,112,116,120,126],{"title":104,"path":105,"stem":107,"sidebarTitle":5},{"title":113,"path":114,"stem":115},"Setup","/sandbox/setup","sandbox/1.setup",{"title":117,"path":118,"stem":119},"Getting Started","/sandbox/getting-started","sandbox/2.getting-started",{"title":121,"path":122,"stem":123,"children":124},"Handbook","/sandbox/handbook","sandbox/3.handbook/0.index",[125],{"title":121,"path":122,"stem":123},{"title":127,"path":128,"stem":129,"children":130,"page":-1},"API Reference","/sandbox/api-reference","sandbox/4.api-reference/index",[131,132,158,175,200],{"title":127,"path":128,"stem":129},{"title":133,"path":134,"stem":135,"children":136,"page":157},"Components","/sandbox/api-reference/components","sandbox/4.api-reference/components",[137,141,145,149,153],{"title":138,"path":139,"stem":140},"KrgzEditorTabs","/sandbox/api-reference/components/krgzeditortabs","sandbox/4.api-reference/components/KrgzEditorTabs",{"title":142,"path":143,"stem":144},"KrgzE