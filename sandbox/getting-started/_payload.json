e and Provide a WebContainer Instance",[14,762,763,764,767,768,771,772,775],{},"Now, import and call ",[24,765,766],{},"useSandboxBoot()",". It is a wrapper around ",[24,769,770],{},"WebContainer.boot()"," and optionally takes a similar\n",[24,773,774],{},"BootOptions"," instance as an argument.",[14,777,778,779,27],{},"After that, provide the resulting promise to through ",[24,780,781],{},"provideWebContainer()",[14,783,784,785,27],{},"Then create the sandbox with ",[24,786,787],{},"useSandbox()",[54,789,791],{"className":56,"code":790,"language":58,"meta":59,"style":59},"// `boot` is the promise returned by WebContainer.boot().\n// `isBooting` is a convenience boolean flag that will be used later to indicate that the sandbox is still booting.\nconst { boot, isBooting } = useSandboxBoot()\n\n// Sub-components and underlying code will await `boot` and use the resulting WebContainer instance. \nprovideWebContainer(boot)\n\n// Must come after provideWebContainer() to able to use the provided boot promise.\nconst sandbox = useSandbox()\n",[24,792,793,798,803,819,823,828,836,840,845],{"__ignoreMap":59},[63,794,795],{"class":65,"line":66},[63,796,797],{"class":69},"// `boot` is the promise returned by WebContainer.boot().\n",[63,799,800],{"class":65,"line":73},[63,801,802],{"class":69},"// `isBooting` is a convenience boolean flag that will be used later to indicate that the sandbox is still booting.\n",[63,804,805,807,810,812,816],{"class":65,"line":79},[63,806,101],{"class":100},[63,808,809],{"class":104}," { boot, isBooting } ",[63,811,109],{"class":108},[63,813,815],{"class":814},"sWDin"," useSandboxBoot",[63,817,818],{"class":104},"()\n",[63,820,821],{"class":65,"line":85},[63,822,192],{"emptyLinePlaceholder":191},[63,824,825],{"class":65,"line":91},[63,826,827],{"class":69},"// Sub-components and underlying code will await `boot` and use the resulting WebContainer instance. \n",[63,829,830,833],{"class":65,"line":97},[63,831,832],{"class":814},"provideWebContainer"