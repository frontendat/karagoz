[{"data":1,"prerenderedAt":1221},["ShallowReactive",2],{"/sandbox/getting-started":3,"sidebar-top-/sandbox":1115,"$rGXtkArH7H":1212,"sidebar-bottom-/sandbox/getting-started":1215,"sidebar-top-title-/sandbox":1122,"sidebar-bottom-title-/sandbox/getting-started":5},{"id":4,"title":5,"body":6,"description":16,"extension":1109,"hideBreadcrumb":1110,"hideToc":1110,"meta":1111,"navigation":191,"path":1112,"seo":1113,"stem":1114},"content_en/sandbox/2.getting-started.md","Getting Started",{"type":7,"value":8,"toc":1102},"minimal",[9,13,17,28,33,36,47,50,53,628,635,757,761,776,782,788,859,863,874,994,998,1001,1025,1029,1036,1092,1098],[10,11,5],"h1",{"id":12},"getting-started",[14,15,16],"p",{},"Initialising Karagöz Sandbox involves a few steps. We will go through the basic steps in this guide.",[18,19,20],"hint",{},[14,21,22,23,27],{},"Unless otherwise mentioned, all imports come from ",[24,25,26],"code",{},"@karagoz/sandbox",".",[29,30,32],"h2",{"id":31},"create-file-system-tree","Create File System Tree",[14,34,35],{},"Start by creating the file structure you want to mount to the WebContainer.",[14,37,38,39,42,43,46],{},"In this example we will create a simple express server that provides an endpoint under ",[24,40,41],{},"api/message",", as well as,\nserves the static files under the ",[24,44,45],{},"public"," directory at the server root.",[14,48,49],{},"The contents of each file will be created as a separate string for better readability.",[14,51,52],{},"This will be a relatively long chunk of code, so bear with me ^^",[54,55,60],"pre",{"className":56,"code":57,"language":58,"meta":59,"style":59},"language-typescript shiki shiki-themes monokai","/**\n * package.json\n * Defines the dependencies to be installed and script to start the server.\n * The server options indicate that it should restart when JS, HTML or CSS files change.\n */\nconst packageJson = `\n{\n  \"name\": \"example-app\",\n  \"type\": \"module\",\n  \"dependencies\": {\n    \"express\": \"latest\",\n    \"nodemon\": \"latest\"\n  },\n  \"scripts\": {\n    \"start\": \"nodemon --watch './' -e js,html,css server.js\"\n  }\n}\n`\n\n/**\n * server.js\n * Configures a web server on port 3111.\n * Defines the endpoint /api/message that returns a string message.\n * Serves the files in /public under the root path /. \n */\nconst serverJs = `\nimport express from 'express'\n\nconst app = express()\nconst port = 3111\n\napp.get('/api/message', (req, res) => {\n  setTimeout(() => res.send('Welcome to a WebContainers app! 🥳'), 1000)\n})\napp.use('/', express.static('public'))\n\napp.listen(port, () => {\n  console.log('App is live at http://localhost:' + port)\n})\n`\n\n/**\n * public/index.html\n * The home page of the server.\n * Links style.css for styling.\n * Embeds script.js and calls the doSomething() function defined within it.\n * IMPORTANT: we're escpaing the script closing tags, otherwise we will get errors. \n */\nconst indexHtml = `\n\u003Chtml>\n\u003Chead>\n    \u003Clink rel=\"stylesheet\" href=\"./style.css\"/>\n\u003C/head>\n\u003Cbody>\n\u003Ch1>Home Page\u003C/h1>\n\u003Cp class=\"response\">Fetching message...\u003C/p>\n\u003Cscript src=\"./script.js\">\u003C${'/script'}>\n\u003Cscript>doSomething()\u003C${'/script'}>\n\u003C/body>\n\u003C/html>\n`\n\n/**\n * public/script.js\n * Defines the function doSomething() that calls the API endpoint /api/messsage\n * and injects the response into the div element with the class \"response\".\n */\nconst scriptJs = `\nfunction doSomething() {\n  fetch('/api/message')\n    .then((response) => response.text())\n    .then((data) => (document.querySelector('.response').innerHTML = data))\n}\n`\n\n/**\n * public/style.css\n * Basic styles.\n */\nconst styleCss = `\nbody {\n  font-family: Arial, Helvetica, sans-serif;\n}\n\nh1 {\n  color: #99cc33;\n}\n`\n","typescript","",[24,61,62,71,77,83,89,95,114,120,126,132,138,144,150,156,162,168,174,180,186,193,198,204,210,216,222,227,239,245,250,256,262,267,273,279,285,291,29