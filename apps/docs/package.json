{
  "name": "@karagoz/docs",
  "private": true,
  "homepage": "https://karagoz.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/frontendat/karagoz.git"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @karagoz/sandbox run docs && NODE_OPTIONS=--max-old-space-size=3584 nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "debug": "pnpm postinstall && nuxt build && nuxthub preview",
    "deploy": "nuxthub deploy"
  },
  "dependencies": {
    "@karagoz/sandbox": "workspace:^",
    "@karagoz/shared": "workspace:^",
    "@nuxt/content": "^3.14.0",
    "@nuxthub/core": "0.10.7",
    "@nuxtjs/color-mode": "^4.0.1",
    "@nuxtjs/i18n": "^10.4.0",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^1.0.0",
    "nuxt": "^4.4.8",
    "radix-vue": "^1.9.17",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "nuxthub": "^0.9.4",
    "vite-plugin-vue-tracer": "^1.4.0",
    "wrangler": "^4.105.0"
  }
}
