{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "tui": { "enabled": true },
  "tasksRunnerOptions": {
    "default": {
      "runner": "nx/tasks-runners/default",
      "options": {
        "cacheDirectory": "node_modules/.cache/nx"
      }
    }
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "outputs": ["{projectRoot}/dist"],
      "cache": true
    },
    "lint": {
      "inputs": ["default", "{workspaceRoot}/oxlint.json"],
      "cache": true
    },
    "docs": {
      "dependsOn": ["build"],
      "outputs": ["{projectRoot}/docs/.generated-docs"],
      "cache": true
    },
    "dev": {
      "dependsOn": ["^build"],
      "continuous": true,
      "cache": false
    },
    "dev-hmr": {
      "dependsOn": ["^build"],
      "continuous": true,
      "cache": false
    },
    "generate": {
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/.output"],
      "cache": true
    }
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": [
      "default",
      "!{projectRoot}/**/*.spec.ts",
      "!{projectRoot}/**/*.test.ts"
    ],
    "sharedGlobals": [
      "{workspaceRoot}/tsconfig.json",
      "{workspaceRoot}/oxlint.json"
    ]
  }
}
